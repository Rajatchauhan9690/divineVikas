          <p>
            <strong>Seat No:</strong> {seatNumber}
          </p>

          <div className="pt-3 border-t">
            <p className="text-sm text-gray-500">Seat Price</p>
            <p className="text-xl font-bold text-green-600">₹{amount}</p>
