          </button>
          <h1 className="text-2xl font-bold">Admin Panel</h1>
        </div>

        {/* Desktop Header */}
        <h1 className="hidden md:block text-3xl font-bold mb-6">Admin Panel</h1>

        {/* ================= CREATE SESSION ================= */}
